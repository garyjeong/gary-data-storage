# Database
DB_NAME=collector
DB_USER=gary
DB_PASSWORD=your_password_here

# Public Data Portal (data.go.kr) - Decoding key
DATA_GO_KR_API_KEY=your_api_key_here

# V-World (공동주택 공시가격)
VWORLD_API_KEY=your_vworld_key_here

# Korea Real Estate Board (한국부동산원)
REB_API_KEY=your_reb_key_here

# Seoul Open Data (서울 열린데이터광장)
SEOUL_API_KEY=your_seoul_key_here

# Gyeonggi Data Dream (경기데이터드림)
GYEONGGI_API_KEY=your_gyeonggi_key_here

# Collection Settings
COLLECTION_INTERVAL_MINUTES=30
PRIVATE_CRAWLER_DELAY=2

# Admin
ADMIN_PORT=8080

# Logging
LOG_LEVEL=INFO
